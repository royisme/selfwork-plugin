{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Analysis Report",
  "type": "object",
  "required": ["run_id", "summary", "codebase_findings", "feasibility", "risks", "recommendations"],
  "properties": {
    "run_id": { "type": "string" },
    "summary": { "type": "string", "description": "Requirement analysis summary" },
    "codebase_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "description"],
        "properties": {
          "path": { "type": "string" },
          "description": { "type": "string" },
          "pattern": { "type": "string", "description": "Existing pattern identified" },
          "reuse_opportunity": { "type": "string" }
        }
      }
    },
    "feasibility": { "type": "string", "enum": ["high", "medium", "low"] },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "severity"],
        "properties": {
          "description": { "type": "string" },
          "severity": { "type": "string", "enum": ["high", "medium", "low"] },
          "mitigation": { "type": "string" }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
