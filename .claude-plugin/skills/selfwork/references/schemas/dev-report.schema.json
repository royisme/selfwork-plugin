{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Developer Report",
  "type": "object",
  "required": ["run_id", "task_id", "files_changed", "test_result"],
  "properties": {
    "run_id": { "type": "string" },
    "task_id": { "type": "string" },
    "files_changed": { "type": "array", "items": { "type": "string" } },
    "tests_written": { "type": "array", "items": { "type": "string" }, "default": [] },
    "test_result": { "type": "string", "enum": ["pass", "fail", "skipped"] },
    "test_output": { "type": "string", "description": "Relevant test output snippet" },
    "notes": { "type": "string" }
  }
}
